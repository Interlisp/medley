                                                                           (MAKEFONTFACE 'MEDIUM NIL
                                                                                  NIL FACE))
                                      FROMDIR)))
                 (AND (EQ 'ITALIC (fetch (FONTFACE SLOPE) of FACE))
                      (FAKEFACE.FROMFILE (create FONTSPEC using FONTSPEC FSFACE ← (MAKEFONTFACE
                                                                                   NIL
                                                                                   'REGULAR NIL FACE)
                                                )
                             FROMDIR))
                 (AND (EQ 'COMPRESSED (fetch (FONTFACE EXPANSION) of FACE))
                      (FAKEFACE.FROMFILE (create FONTSPEC using FONTSPEC FSFACE ← (MAKEFONTFACE
                                                                                   NIL NIL
                                                                                   'REGULAR FACE))
