                                             "Make sure we copy consistent versions of the indirects")
                         (SORTFONTSPECS (CL:REMOVE-DUPLICATES (APPEND
                                                               (for FS in EXPANDED
                                                                  join (MEDLEYFONT.GETFILEPROP
                                                                        (MEDLEYFONT.FILENAME FS 
                                                                               FROMDIR)
                                                                        'INDIRECTS))
                                                               EXPANDED)
