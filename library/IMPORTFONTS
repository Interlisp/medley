        (LET [(EXPANDED (CL:REMOVE-DUPLICATES
                         (for F inside (CL:IF (type? FONTSPEC FONTSPECS)
                                           (CONS FONTSPECS)
                                           (OR FONTSPECS '*))
                            join (if (type? FONTSPEC F)
                                     then (for FACE in (FONTFACE.STARS (fetch (FONTSPEC FSFACE)
                                                                          of (\FONT.CHECKARGS F)))
