                                         (AND NOERROR (RETFROM (FUNCTION PSEUDOHOST)
                                                             NIL))
                                         (ERROR "Unknown target host" TARGETHOST)))
                  (if (NULL (SETQ PHDEV (\GETDEVICEFROMNAME HOST T)))
                      then (SETQ PHDEV
                            (create FDEV
                               using TARGETDEVICE DEVICENAME _ HOST FDEV1 _ TARGETDEVICE FDEV2 _ 
                                     TRUEPREFIX FDEV4 _ PREFIX OPENFILELST _ NIL OPENFILE _
                                     (FUNCTION OPENFILE.PH)
