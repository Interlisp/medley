                                     GETFILEINFO _ (FUNCTION GETFILEINFO.PH)
                                     SETFILEINFO _ (FUNCTION SETFILEINFO.PH)))
                           (UNINTERRUPTABLY
                               (\DEFINEDEVICE HOST PHDEV)
                               (PSEUDOHOST.PREFIXMAP HOST TRUEPREFIX))
                    elseif (type? PHDEVICE PHDEV)
                      then 
                           (* ;; "New prefix for an existing pseudohost")

                           (UNINTERRUPTABLY
                               (replace (PHDEVICE TRUEPREFIX) of PHDEV with TRUEPREFIX)
