                       (\DEFINEDEVICE HOST NIL)))
      elseif NOERROR
      else (ERROR (CONCAT "PREFIX FOR PSEUDOHOST " HOST " NOT FOUND")))
    (CL:WHEN (AND PREFIX CDSUFFIX)
           (CDPSEUDO HOST CDSUFFIX))
    (CL:WHEN PREFIX                                          (* ; 
                                                           "If no prefix, we didn't get a pseudohost")
        HOST)])

