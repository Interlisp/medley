    (* ;; "Edited 24-Feb-2022 23:56 by rmk: Expand prefix so that it is rooted in a real host and not a previously defined pseudohost.")

    (DECLARE (GLOBALVARS \FILEDEVICES))
    (CL:WHEN (AND (LISTP HOST)
