                                                                 (* ;; 
                                                                "Sort the range alternatives, if any")

                                                                 (change (CDR M)
                                                                        (SORT DATUM))) 

                             (* ;; "Sort by domain codes and push down a level")

                             (change (CDR CS)
                                    (SORT DATUM T)))
