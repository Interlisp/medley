(DEFINEQ

(\TFBRAVO.INSERT.PARA
  [LAMBDA (PARA BSTREAM TSTREAM)                             (* ; "Edited  5-Jul-2026 22:06 by rmk")
                                                             (* ; "Edited 14-Jun-2026 14:48 by rmk")
                                                             (* ; "Edited  8-Feb-2025 23:06 by rmk")
                                                             (* ; "Edited 20-Aug-2023 16:13 by rmk")

    (* ;; "Inserts pieces into TEXTOBJ that correspond to the charlooks runs in PARA.  The runs in PARA may have internal formatting characters (CR, LF, TAB, FORM) that have to be split out in separate pieces.")

    (* ;; 
    "PARATABDEFS of PARA contains the definitions of named tags, for all the runs of this paragraph.")

    (* ;; "RUNTABS contains a list of named tags that are explicity specified for this run, by tn entries in the charlooks.  If RUNTABS is empty, then the successive tab characters in the FORMATPTRS are paired with the successive tabs in the PARATABDEFS.")

    (* ;; "However they are identified, named tabs are converted to image objects that either replace the successive tab characters")

    (DECLARE (USEDFREE NAMEDTABS))
    (for RUN PC UNSETNEXTTAB TABNAME TABX PARALOOKS RUNSTARTCHNO RUNTABS (TEXTOBJ _ (FGETTSTR TSTREAM
                                                                                           TEXTOBJ))
         [FILEPOS _ (fetch (RUN RUNSTART) of (CAR (fetch (PARA RUNS) of PARA]
       in (fetch (PARA RUNS) of PARA) first (SETQ PARALOOKS (\TEDIT.UNIQUIFY.PARALOOKS
                                                             (fetch (PARA PARAPLOOKS) of PARA)
                                                             TEXTOBJ))
       when (IGREATERP (fetch (RUN RUNLENGTH) of RUN)
                   0)
       do (AND NIL (\TFBRAVO.RUN.TABSPEC RUN PARALOOKS TEXTOBJ))
          (SETQ RUNSTARTCHNO (ADD1 (TEXTLEN TEXTOBJ)))
          (SETQ RUNTABS (fetch (RUN RUNTABS) of RUN))
          (SETQ PC (create PIECE
                          PTYPE _ THINFILE.PTYPE
                          PCONTENTS _ BSTREAM
                          PFPOS _ FILEPOS
                          PLEN _ (fetch (RUN RUNLENGTH) of RUN)
                          PBYTESPERCHAR _ 1
                          PCHARLOOKS _ (\TEDIT.UNIQUIFY.CHARLOOKS (fetch (RUN RUNLOOKS) of RUN)
                                              TEXTOBJ)
                          PPARALOOKS _ PARALOOKS)) 

          (* ;; 
 "Insert a piece for the run, then walk through and  chop it up to replace any formatting characters")

          (\TEDIT.INSERTPIECE PC NIL TEXTOBJ)
          (for FPTR TABX in (fetch (RUN RUNFORMATPTRS) of RUN)
             do 
                (* ;; "FPTR's are run-relative")

                (SELECTQ (CAR FPTR)
                    (EOL (\TEDIT.NTHCHARCODE TSTREAM (IPLUS RUNSTARTCHNO (CADR FPTR)))
                         (\TEDIT.RPLCHARCODE TSTREAM (IPLUS RUNSTARTCHNO (CADR FPTR))
                                (CHARCODE Meta,EOL)))
                    (TAB (CL:WHEN (AND RUNTABS NAMEDTABS)    (* ; 
                                                             "If not named, leave as an interval tab")
                             (SETQ TABNAME (pop RUNTABS))
                             (if (EQ TABNAME 0)
                                 then 
                                      (* ;; "Unset the next tab, leave it as a tab character?")

                                      (SETQ UNSETNEXTTAB T)
                               else (CL:WHEN (AND TABNAME (NOT UNSETNEXTTAB)
                                                  (SETQ TABX (GETMULTI NAMEDTABS TABNAME)))
                                                             (* ; 
                                                      "Replace the named TAB with a tab image object")
                                        (\TEDIT.RPLCHARCODE TSTREAM (IPLUS RUNSTARTCHNO (CADR FPTR))
                                               (TEDIT.TABOBJ (IDIFFERENCE TABX (GETPLOOKS PARALOOKS 
                                                                                      LEFTMAR))
                                                      TABNAME)))
                                    (SETQ UNSETNEXTTAB NIL))))
                    (FORM                                    (* ; 
                                                           "Pargraph break or leave alone?  Not sure"))
                    (SHOULDNT)))
          (add FILEPOS (fetch (RUN RUNLENGTH) of RUN))
       finally 

             (* ;; "Replace ^z with EOL, but maybe no ^z at EOF.  OFFSET is alredy PC-relative")

             (CL:WHEN [EQ (CHARCODE ^z)
                          (\TEDIT.PIECE.NTHCHARCODE PC (SUB1 (PLEN PC]
                 (\TEDIT.PIECE.RPLCHARCODE TEXTOBJ PC (SUB1 (PLEN PC))
                        (CHARCODE EOL)))])

(\TFBRAVO.INSERT.RUN
  [LAMBDA (RUN BSTREAM PARALOOKS TEXTOBJ)                    (* ; "Edited 30-Jun-2026 21:30 by rmk")
                                                             (* ; "Edited 10-Apr-2026 09:22 by rmk")
                                                             (* ; "Edited 28-Jul-2025 23:33 by rmk")
                                                             (* ; "Edited  8-Feb-2025 23:08 by rmk")
                                                             (* ; "Edited 17-Mar-2024 12:41 by rmk")
                                                             (* ; "Edited 16-Jan-2024 18:28 by rmk")
                                                             (* ; "Edited 29-Dec-2023 11:50 by rmk")
                                                             (* ; "Edited 23-Sep-2023 12:11 by rmk")
                                                             (* ; "Edited 23-Aug-2023 08:31 by rmk")
                                                             (* ; "Edited 20-Aug-2023 16:12 by rmk")
                                                             (* ; "Edited 19-Aug-2023 14:47 by rmk")

    (* ;; "A Bravo run can include many CR's each of which should end a separate TEDIT paragraph.  Unless we want to think of those as paragraph internal meta-CRs ?")

    (* ;; "PARALOOKS is the intended paragraph PARALOOKS for the paragraph, providing the margins, line leading etc. common to all runs.  It may be specialized for each run to encode the tabs that that run actually selects (via \TFBRAVO.RUN.TABSPEC")

