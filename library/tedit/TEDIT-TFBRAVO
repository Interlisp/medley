                                                             (* ; "Edited 15-Jun-2026 13:43 by rmk")
                                                             (* ; "Edited 22-Sep-2023 20:04 by rmk")
                                                             (* ; "Edited 17-Aug-2023 14:31 by rmk")
                                                            (* ; "Edited 13-Jun-90 01:00 by mitani")

    (* ;; "using the information from the profile paragraphs, this function installs the pageframes")

    (LET ((TEXTOBJ (GETTSTR TSTREAM TEXTOBJ))
          FIRSTPAGENO PAGENUMBERS TOPMARGIN BOTTOMMARGIN NUMBEROFCOLUMNS BETWEENCOLUMNS COLUMNWIDTH 
          HEADING.NOTONFIRSTPAGE PAGENUMBER.NOTONFIRSTPAGE RIGHTHEADING.NOTONFIRSTPAGE 
          LEFTHEADING.NOTONFIRSTPAGE FIRST LEFT RIGHT PAGEPROPS LEFTPAGENUMPARA RIGHTPAGENUMPARA 
          FIRSTHEADINGLIST LEFTHEADINGLIST DEFAULTHEADINGLIST RIGHTHEADINGLIST FIRSTHEADINGLIST 
          PAGENUMBERY BINDING EDGEMARGIN)
         (DECLARE (SPECVARS . T))
         (for VAR
            in '(FIRSTPAGENO PAGENUMBERS TOPMARGIN BOTTOMMARGIN NUMBEROFCOLUMNS COLUMNWIDTH 
                       BETWEENCOLUMNS LEFTHEADINGLIST DEFAULTHEADINGLIST RIGHTHEADINGLIST 
                       HEADING.NOTONFIRSTPAGE PAGENUMBER.NOTONFIRSTPAGE RIGHTHEADING.NOTONFIRSTPAGE 
                       LEFTHEADING.NOTONFIRSTPAGE PAGENUMBERY BINDING EDGEMARGIN)
            do (SET VAR (GETBPROP TEXTOBJ VAR)))

         (* ;; "This assumes that TEdit does not build a default page spec.  If it ever does, then this logic must change.")

         (* ;; "the default page frame is always built.  It is sometimes built as the only page frame when there is no headings specified.  However, if heading is specified with the not-on-first-page specified, then we must build the default page frame simply for that reason")

         (CL:WHEN NUMBEROFCOLUMNS

             (* ;; "If this is to be printed multicolumn then determine the column width from the numberofcolumns and the space between them. ")

             (SETQ COLUMNWIDTH (IQUOTIENT (IDIFFERENCE [IDIFFERENCE (CONSTANT (TIMES 8.5 PTSPERINCH))
                                                              (ITIMES 2 (GETBPROP TEXTOBJ
                                                                               'EDGEMARGIN]
                                                 (ITIMES (SUB1 NUMBEROFCOLUMNS)
                                                        BETWEENCOLUMNS))
                                      NUMBEROFCOLUMNS)))

         (* ;; "")

         (* ;; "Headings")

         (CL:UNLESS LEFTHEADINGLIST (SETQ LEFTHEADINGLIST DEFAULTHEADINGLIST))
         (CL:UNLESS RIGHTHEADINGLIST (SETQ RIGHTHEADINGLIST DEFAULTHEADINGLIST))
         (CL:UNLESS HEADING.NOTONFIRSTPAGE                   (* ; "Is left a fallback option?")
             (SETQ FIRSTHEADINGLIST (OR (CL:UNLESS RIGHTHEADING.NOTONFIRSTPAGE RIGHTHEADINGLIST)
                                        DEFAULTHEADINGLIST
                                        (CL:UNLESS LEFTHEADING.NOTONFIRSTPAGE LEFTHEADINGLIST))))
         (CL:UNLESS BINDING (SETQ BINDING 0))
         (SETQ BINDING 0)

         (* ;; "")

         (* ;; "Page numbers")

         (CL:UNLESS (EQ PAGENUMBERS 'NO)                     (* ; 
                                                        "Since PAGENO is in objects, disable folios ")

             (* ;; "Bravo page numbers are upper right--move down to baseline")

             [add PAGENUMBERY (MINUS (FONTPROP (GETCLOOKS (GETTOBJ TEXTOBJ DEFAULTCHARLOOKS)
                                                      CLFONT)
                                            'ASCENT]
             [SETQ PAGEPROPS `(STARTINGPAGE# ,(OR FIRSTPAGENO 1]
             (SETQ LEFTPAGENUMPARA (\TEDIT.PAGENO.PARAGRAPH TEXTOBJ 'Leftpagenumber
                                          (GETBPROP TEXTOBJ 'ROMAN)
                                          0 PAGENUMBERY 'LEFT))
             (SETQ RIGHTPAGENUMPARA (\TEDIT.PAGENO.PARAGRAPH TEXTOBJ 'Rightpagenumber
                                           (GETBPROP TEXTOBJ 'ROMAN)
                                           (GETBPROP TEXTOBJ 'PAGENUMBERX)
                                           PAGENUMBERY
                                           'RIGHT))
             (\TEDIT.INSERT.SELPIECES RIGHTPAGENUMPARA TSTREAM 1)
                                                             (* ; "Left ends up in front of right")
             (\TEDIT.INSERT.SELPIECES LEFTPAGENUMPARA TSTREAM 1)
             (CL:UNLESS PAGENUMBER.NOTONFIRSTPAGE
                 (push FIRSTHEADINGLIST (LIST 'Rightpagenumber 0 PAGENUMBERY)))
             (push LEFTHEADINGLIST (LIST 'Leftpagenumber 0 PAGENUMBERY))
             (push RIGHTHEADINGLIST (LIST 'Rightpagenumber 0 PAGENUMBERY)))

         (* ;; "")

         (* ;; "Page formats")

         (SETQ FIRST (TEDIT.SINGLE.PAGEFORMAT NIL NIL NIL NIL NIL (MINUS BINDING)
                            0 TOPMARGIN BOTTOMMARGIN NUMBEROFCOLUMNS COLUMNWIDTH BETWEENCOLUMNS 
                            FIRSTHEADINGLIST 'POINTS PAGEPROPS))
         (SETQ LEFT (TEDIT.SINGLE.PAGEFORMAT NIL NIL NIL NIL NIL (MINUS BINDING)
                           0 TOPMARGIN BOTTOMMARGIN NUMBEROFCOLUMNS COLUMNWIDTH BETWEENCOLUMNS 
                           LEFTHEADINGLIST 'POINTS PAGEPROPS))
         (SETQ RIGHT (TEDIT.SINGLE.PAGEFORMAT NIL NIL NIL NIL NIL BINDING 0 TOPMARGIN BOTTOMMARGIN 
                            NUMBEROFCOLUMNS COLUMNWIDTH BETWEENCOLUMNS RIGHTHEADINGLIST 'POINTS 
                            PAGEPROPS))
         (TEDIT.PAGEFORMAT TEXTOBJ (TEDIT.COMPOUND.PAGEFORMAT FIRST LEFT RIGHT])
)
