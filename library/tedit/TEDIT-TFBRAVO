                   (SETQ TABX (\TFBRAVO.READNUM? BSTREAM T)) (* ; "Name or X position")

                   (* ;; "Tabs apparently round down/truncate, not up.")

                   (SELCHARQ (SETQ COMMAND (BIN BSTREAM))
