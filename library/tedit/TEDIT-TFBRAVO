                                                             (* ; "Edited  9-Sep-2023 21:41 by rmk")
                                                             (* ; "Edited 20-Aug-2023 23:03 by rmk")

    (* ;; "A run is a sequence of characters within a paragraph that have the same charlooks")

    (bind RUNS RUN RLEN (RUNSTART _ PARASTART)
          (OLDCHARLOOKS _ (GETBPROP TEXTOBJ 'USER.CM.CHARLOOKS))
       do (SETQ RUN (\TFBRAVO.READ.CHARLOOKS TEXTOBJ BSTREAM OLDCHARLOOKS RUNSTART PARALEN)) 

          (* ;; "Assign FORMATPTRS to their runs")

          (for FPTAIL FPTR (ENDRUN _ (IPLUS RUNSTART (fetch (RUN RUNLENGTH) of RUN))) on FORMATPTRS
             eachtime (SETQ FPTR (CAR FPTAIL)) while (ILESSP (CADR FPTR)
                                                            ENDRUN)
             collect 

                   (* ;; "Make pointers RUN-relative ")

                   (change (CADR FPTR)
                          (IDIFFERENCE DATUM RUNSTART))
                   FPTR finally (replace (RUN RUNFORMATPTRS) of RUN with $$VAL)
                              (SETQ FORMATPTRS FPTAIL))
          (push RUNS RUN)
          (SETQ OLDCHARLOOKS (fetch (RUN RUNLOOKS) of RUN))
          (CL:WHEN (fetch (RUN RUNLAST) of RUN)
              (RETURN (DREVERSE RUNS)))
          (SETQ RLEN (fetch (RUN RUNLENGTH) of RUN))         (* ; "Set up for next run")
