                                                            (* \; "Edited 28-Feb-2025 23:51 by rmk")
                                                            (* \; "Edited 25-Feb-2025 22:44 by rmk")
                                                             (* |fsg| "28-Jul-87 11:12")

    (* |;;| "Convert the value NCOUNT to the type specified by CHARTYPE.  If NCOUNT < 1 and CHARTYPE is Letter/Roman then we return NIL.  This anomaly is usually caused by out-of-order NGroups.")

    (CL:UNLESS (FIXP NCOUNT)
           (ERROR "Invalid integer" NCOUNT))
    (LET ((CHARTYPE (|fetch| (NGTEMPLATE NG.CHARTYPE) |of| TEMPLATE)))
         (CL:UNLESS (AND (ILEQ NCOUNT 1)
                         (NOT (MEMB CHARTYPE '(|Number| |Null String|))))
             (SELECTQ CHARTYPE
                 (UPPERCASE\ LETTER 
                      (NUMBER.TO.LETTER NCOUNT T))
                 (|lowercase letter| 
                      (NUMBER.TO.LETTER NCOUNT))
                 (UPPERCASE\ ROMAN 
                      (ROMANNUMERALS NCOUNT T))
                 (|lowercase roman| 
                      (ROMANNUMERALS NCOUNT))
                 (|Null String| "")
                 (|Number| (MKSTRING NCOUNT))
                 (ERROR "Unknown display type" CHARTYPE))))))

